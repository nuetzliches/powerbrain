{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerbrain.dev/schemas/policy-data.json",
  "title": "Powerbrain OPA Policy Data",
  "description": "JSON Schema for data.json — configurable policy data consumed by OPA Rego rules",
  "type": "object",
  "required": ["pb"],
  "additionalProperties": false,
  "properties": {
    "pb": {
      "type": "object",
      "required": ["config"],
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "object",
          "required": [
            "roles", "classifications", "access_matrix",
            "write_roles", "write_classifications",
            "allowed_purposes", "retention_days", "retention_obligations",
            "fields_to_redact", "pii_actions", "pii_entity_types", "graph_pii_keys",
            "audit", "ingestion", "human_oversight", "incidents", "drift", "proxy", "summarization", "rules"
          ],
          "additionalProperties": false,
          "properties": {
            "roles": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "All available agent roles"
            },
            "classifications": {
              "type": "array",
              "items": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
              "minItems": 1,
              "description": "Data classification levels (ordered by sensitivity)"
            },
            "access_matrix": {
              "type": "object",
              "description": "Maps classification → list of roles allowed to read",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "write_roles": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Roles allowed to write data"
            },
            "write_classifications": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Classifications that can be written to"
            },
            "allowed_purposes": {
              "type": "object",
              "description": "Maps data_category → list of allowed processing purposes",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "retention_days": {
              "type": "object",
              "description": "Maps data_category → retention period in days",
              "required": ["default"],
              "properties": {
                "default": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": { "type": "integer", "minimum": 1 }
            },
            "retention_obligations": {
              "type": "object",
              "description": "Maps data_category → legal retention obligation in days (blocks deletion)",
              "additionalProperties": { "type": "integer", "minimum": 1 }
            },
            "fields_to_redact": {
              "type": "object",
              "description": "Maps purpose → list of PII fields to redact",
              "required": ["default"],
              "properties": {
                "default": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "pii_actions": {
              "type": "object",
              "description": "Maps classification → PII handling action",
              "additionalProperties": {
                "type": "string",
                "enum": ["mask", "pseudonymize", "encrypt_and_store", "block"]
              }
            },
            "pii_entity_types": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Presidio entity types to scan for"
            },
            "graph_pii_keys": {
              "type": "object",
              "description": "Maps graph property keys (lower-cased) to Presidio entity-type labels. Values at these keys are deterministically replaced with <ENTITY_TYPE> before graph_query / graph_mutate results are returned. Editable at runtime via manage_policies.",
              "additionalProperties": { "type": "string" }
            },
            "audit": {
              "type": "object",
              "description": "EU AI Act Art. 12 audit-log configuration (hash chain + retention)",
              "required": ["retention_days", "advisory_lock_id", "export_max_rows", "export_default_rows", "export_formats"],
              "additionalProperties": false,
              "properties": {
                "retention_days": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Audit log retention in days before checkpoint+prune"
                },
                "advisory_lock_id": {
                  "type": "integer",
                  "description": "pg_advisory_xact_lock id used to serialize audit-chain writes"
                },
                "export_max_rows": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Hard cap on rows returned by export_audit_log"
                },
                "export_default_rows": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Default row limit when export_audit_log is called without limit"
                },
                "export_formats": {
                  "type": "array",
                  "items": { "type": "string", "enum": ["json", "csv"] },
                  "minItems": 1,
                  "description": "Allowed export formats"
                }
              }
            },
            "human_oversight": {
              "type": "object",
              "description": "EU AI Act Art. 14 human oversight configuration",
              "required": ["requires_approval_matrix", "pending_review_timeout_minutes", "max_pending_per_agent"],
              "additionalProperties": false,
              "properties": {
                "requires_approval_matrix": {
                  "type": "object",
                  "description": "Maps classification → list of roles that require human approval",
                  "additionalProperties": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "pending_review_timeout_minutes": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "How long a pending review stays open before the pb-worker marks it expired"
                },
                "max_pending_per_agent": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Per-agent cap on concurrently pending reviews"
                }
              }
            },
            "incidents": {
              "type": "object",
              "description": "GDPR Art. 33/34 privacy-incident workflow configuration: risk scoring, RBAC, deadline thresholds",
              "required": ["risk_score", "roles", "deadline"],
              "additionalProperties": false,
              "properties": {
                "risk_score": {
                  "type": "object",
                  "description": "Risk-score weights and thresholds for assess_incident",
                  "required": [
                    "high_pii_types", "medium_pii_types", "low_pii_types",
                    "weights", "subject_multipliers",
                    "category_multiplier_restricted", "category_multiplier_confidential",
                    "notifiable_threshold"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "high_pii_types": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Presidio entity types that contribute the high weight"
                    },
                    "medium_pii_types": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "low_pii_types": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "weights": {
                      "type": "object",
                      "required": ["high", "medium", "low"],
                      "additionalProperties": false,
                      "properties": {
                        "high":   { "type": "number", "minimum": 0 },
                        "medium": { "type": "number", "minimum": 0 },
                        "low":    { "type": "number", "minimum": 0 }
                      }
                    },
                    "subject_multipliers": {
                      "type": "array",
                      "description": "Brackets of (min subjects → multiplier). Effective multiplier is the max with min ≤ actual count.",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "required": ["min", "multiplier"],
                        "additionalProperties": false,
                        "properties": {
                          "min":        { "type": "integer", "minimum": 0 },
                          "multiplier": { "type": "number",  "minimum": 0 }
                        }
                      }
                    },
                    "category_multiplier_restricted":   { "type": "number", "minimum": 0 },
                    "category_multiplier_confidential": { "type": "number", "minimum": 0 },
                    "notifiable_threshold": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Score above which an incident is marked notifiable (Art. 33 risk to rights and freedoms)"
                    }
                  }
                },
                "roles": {
                  "type": "object",
                  "description": "RBAC: which roles may invoke each incident tool",
                  "required": [
                    "allow_report", "allow_list", "allow_assess",
                    "allow_notify_authority", "allow_notify_subject"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "allow_report":           { "type": "array", "items": { "type": "string" } },
                    "allow_list":             { "type": "array", "items": { "type": "string" } },
                    "allow_assess":           { "type": "array", "items": { "type": "string" } },
                    "allow_notify_authority": { "type": "array", "items": { "type": "string" } },
                    "allow_notify_subject":   { "type": "array", "items": { "type": "string" } }
                  }
                },
                "deadline": {
                  "type": "object",
                  "description": "GDPR Art. 33 timing — used by incident_deadline_check worker job and the v_incidents_requiring_attention view",
                  "required": ["notification_hours", "warning_threshold_hours", "critical_threshold_hours"],
                  "additionalProperties": false,
                  "properties": {
                    "notification_hours": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Hard deadline for supervisory authority notification (Art. 33: 72)"
                    },
                    "warning_threshold_hours": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Below this, mark as warning. Default 24."
                    },
                    "critical_threshold_hours": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Above this and before notification_hours, mark as critical. Default 48."
                    }
                  }
                }
              }
            },
            "drift": {
              "type": "object",
              "description": "EU AI Act Art. 15 embedding drift detection configuration",
              "required": ["thresholds", "reference_sample_size", "fresh_sample_size"],
              "additionalProperties": false,
              "properties": {
                "thresholds": {
                  "type": "object",
                  "description": "Per-collection cosine-distance thresholds; 'default' is required",
                  "required": ["default"],
                  "additionalProperties": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
                  "properties": {
                    "default": { "type": "number", "minimum": 0.0, "maximum": 2.0 }
                  }
                },
                "reference_sample_size": {
                  "type": "integer",
                  "minimum": 10,
                  "description": "Number of vectors sampled from each collection at deployment to form the baseline centroid"
                },
                "fresh_sample_size": {
                  "type": "integer",
                  "minimum": 10,
                  "description": "Number of recent vectors sampled per refresh to compute the fresh centroid"
                }
              }
            },
            "ingestion": {
              "type": "object",
              "description": "EU AI Act Art. 10 data-quality gate configuration",
              "required": ["min_quality_score", "duplicate_threshold"],
              "additionalProperties": false,
              "properties": {
                "min_quality_score": {
                  "type": "object",
                  "description": "Minimum quality_score per source_type; 'default' is required",
                  "required": ["default"],
                  "additionalProperties": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                  "properties": {
                    "default": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
                  }
                },
                "duplicate_threshold": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Cosine-similarity threshold for duplicate detection on first-chunk embeddings"
                },
                "pii_verifier": {
                  "type": "object",
                  "description": "Semantic PII verifier (Presidio precision filter). When enabled, ambiguous entity candidates (PERSON / LOCATION / ORGANIZATION) are sent to a chat LLM which decides per-candidate whether the hit is real PII or a false positive (e.g. a German compound noun). Community default: off (noop backend). Enterprise / regulated deployments flip this on to cut false-positive rate without sacrificing recall.",
                  "required": ["enabled", "backend", "min_confidence_keep"],
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Master switch — when false the ingestion pipeline behaves exactly as it did before the verifier was introduced"
                    },
                    "backend": {
                      "type": "string",
                      "enum": ["noop", "llm"],
                      "description": "noop = pass-through. llm = OpenAI-compatible chat endpoint (Ollama, vLLM, OpenAI, ...). Configured via PII_VERIFIER_URL / PII_VERIFIER_MODEL env vars."
                    },
                    "min_confidence_keep": {
                      "type": "number",
                      "minimum": 0.0,
                      "maximum": 1.0,
                      "description": "Below this confidence, the verifier treats an ambiguous candidate as a false positive and drops it"
                    }
                  }
                }
              }
            },
            "proxy": {
              "type": "object",
              "required": ["allowed_roles", "required_tools", "max_iterations", "elevated_roles", "default_mcp_servers", "documents", "pii_resolve_tool_results"],
              "additionalProperties": false,
              "properties": {
                "allowed_roles": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Roles allowed to use the AI proxy"
                },
                "required_tools": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "MCP tools injected into every request"
                },
                "max_iterations": {
                  "type": "object",
                  "required": ["default", "elevated"],
                  "additionalProperties": false,
                  "properties": {
                    "default": { "type": "integer", "minimum": 1 },
                    "elevated": { "type": "integer", "minimum": 1 }
                  }
                },
                "elevated_roles": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Roles that get elevated iteration limits and full MCP server access"
                },
                "default_mcp_servers": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "MCP servers accessible to non-elevated roles"
                },
                "pii_resolve_tool_results": {
                  "type": "object",
                  "description": "Enterprise-edition pb-proxy feature: after the MCP tool returns content containing [TYPE:hash] pseudonyms, the proxy calls mcp-server /vault/resolve to substitute originals subject to OPA vault_access_allowed and vault_fields_to_redact for the declared purpose. Disabled → proxy behaves like community (pseudonyms flow straight through).",
                  "required": ["enabled", "allowed_roles", "allowed_purposes", "default_purpose"],
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Master switch. False turns pb-proxy into a community-equivalent layer for PII."
                    },
                    "allowed_roles": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Roles that may trigger vault resolution through the proxy"
                    },
                    "allowed_purposes": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1,
                      "description": "Purposes the proxy may declare when calling /vault/resolve. Must be a subset of `allowed_purposes[data_category]` for at least one category the proxy handles."
                    },
                    "default_purpose": {
                      "type": "string",
                      "description": "Purpose the proxy uses when the caller did not supply one (header/query/body)."
                    }
                  }
                },
                "documents": {
                  "type": "object",
                  "description": "Document-attachment policy for the chat endpoint (PDF, DOCX, XLSX, ...).",
                  "required": ["allowed_roles", "max_bytes", "allowed_mime_types", "max_files_per_request"],
                  "additionalProperties": false,
                  "properties": {
                    "allowed_roles": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Roles that may attach documents to chat messages"
                    },
                    "max_bytes": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Per-file size cap in bytes"
                    },
                    "allowed_mime_types": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1,
                      "description": "Canonical MIME types the extractor will process"
                    },
                    "max_files_per_request": {
                      "type": "object",
                      "required": ["default", "elevated"],
                      "additionalProperties": false,
                      "properties": {
                        "default": { "type": "integer", "minimum": 0 },
                        "elevated": { "type": "integer", "minimum": 0 }
                      }
                    }
                  }
                }
              }
            },
            "summarization": {
              "type": "object",
              "required": ["denied_roles", "required_classifications", "brief_classifications"],
              "additionalProperties": false,
              "properties": {
                "denied_roles": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Roles that may NOT request summaries"
                },
                "required_classifications": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Classifications where summarization is mandatory (no raw chunks)"
                },
                "brief_classifications": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Classifications limited to brief summaries only"
                }
              }
            },
            "rules": {
              "type": "object",
              "description": "Business rules by category, queried by agents",
              "additionalProperties": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}
