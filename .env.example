# ============================================================
#  Wissensdatenbank – Umgebungsvariablen
#  Kopiere nach .env und passe an: cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
PG_PASSWORD=changeme_in_production

# ── Forgejo (vorhandene Instanz) ────────────────────────────
FORGEJO_URL=http://forgejo.local:3000
FORGEJO_TOKEN=dein_forgejo_api_token

# ── Reranker ────────────────────────────────────────────────
# Modell-Optionen:
#   cross-encoder/ms-marco-MiniLM-L-6-v2   (schnell, EN)
#   cross-encoder/ms-marco-MiniLM-L-12-v2  (genauer, EN)
#   BAAI/bge-reranker-v2-m3                (multilingual DE+EN)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true
