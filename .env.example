# ============================================================
#  Powerbrain – Environment Variables
#  Copy to .env and adjust: cp .env.example .env
#
#  Secrets can also be provided as Docker Secrets files in
#  ./secrets/*.txt (see docs/deployment.md). Docker Secrets
#  take precedence over env vars when both are set.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
# Also available as Docker Secret: secrets/pg_password.txt
PG_PASSWORD=changeme_in_production

# ── Forgejo (existing instance) ─────────────────────────────
FORGEJO_URL=http://forgejo.local:3000
# Also available as Docker Secret: secrets/forgejo_token.txt
FORGEJO_TOKEN=your_forgejo_api_token

# ── Vault HMAC Secret ──────────────────────────────────────
# Also available as Docker Secret: secrets/vault_hmac_secret.txt
# VAULT_HMAC_SECRET=change-me-in-production

# ── Reranker ────────────────────────────────────────────────
# Model options:
#   cross-encoder/ms-marco-MiniLM-L-6-v2   (fast, EN)
#   cross-encoder/ms-marco-MiniLM-L-12-v2  (more accurate, EN)
#   BAAI/bge-reranker-v2-m3                (multilingual DE+EN)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# ── Authentication ──────────────────────────────────────────
# Authentication (true = require API keys, false = allow unauthenticated access)
AUTH_REQUIRED=true

# ── Rate Limiting ───────────────────────────────────────────
# Toggle rate limiting on/off
RATE_LIMIT_ENABLED=true
# Requests per minute per agent, by role
RATE_LIMIT_ANALYST=60
RATE_LIMIT_DEVELOPER=120
RATE_LIMIT_ADMIN=300

# ── Summarization ───────────────────────────────────────────
# Model for context summarization (runs on Ollama)
SUMMARIZATION_MODEL=qwen2.5:3b
SUMMARIZATION_ENABLED=true

# ── TLS (optional, activate with: docker compose --profile tls up) ──
# DOMAIN=kb.example.com
