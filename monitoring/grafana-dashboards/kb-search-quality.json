{
  "title": "KB Search Quality",
  "uid": "kb-search-quality",
  "tags": ["kb", "feedback", "eval"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg Feedback Rating (letzte 24h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "kb_feedback_avg_rating",
        "legendFormat": "avg rating"
      }],
      "options": { "thresholds": { "steps": [
        { "color": "red",    "value": 0   },
        { "color": "yellow", "value": 2.5 },
        { "color": "green",  "value": 4.0 }
      ]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reranker aktiv",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"reranker\"}",
        "legendFormat": "reranker up"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Suchergebnisse pro Request (p50 / p95)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by(le, collection) (rate(kb_mcp_search_results_count_bucket[5m])))",
          "legendFormat": "p50 {{collection}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by(le, collection) (rate(kb_mcp_search_results_count_bucket[5m])))",
          "legendFormat": "p95 {{collection}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reranker Latenz p50 / p95",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(kb_reranker_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(kb_reranker_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reranker Fallbacks (Graceful Degradation)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "increase(kb_mcp_rerank_fallback_total[10m])",
        "legendFormat": "Fallbacks / 10min"
      }]
    }
  ]
}
