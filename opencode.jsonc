{
  "$schema": "https://opencode.ai/config.json",
  // ── Powerbrain Proxy Provider ─────────────────────────────
  // Routes LLM requests through pb-proxy (PII pseudonymization +
  // Powerbrain tool injection).
  // Activate: docker compose --profile proxy up -d
  // Auth: /connect → Other → id "powerbrain-proxy" → your provider API key
  //   (e.g. Anthropic key for Claude models). The proxy forwards it to
  //   the LLM provider. If no key is set, the proxy uses its central key
  //   from secrets/anthropic_api_key.txt.
  "provider": {
    "powerbrain-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Powerbrain Proxy",
      "options": {
        "baseURL": "http://localhost:8090/v1"
      },
      "models": {
        "claude-opus": {
          "name": "Claude Opus 4 (via Powerbrain)",
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "gpt-4o": {
          "name": "GPT-4o (via Powerbrain)",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
      // BACKLOG: Haiku support — Anthropic model ID mismatch.
      // The proxy tried claude-3-5-haiku-20241022, but Anthropic returned
      // "not_found_error". OpenCode shows "Claude Haiku 3.5 (latest)" with
      // an unknown internal model ID. Need to determine the exact model name
      // on your Anthropic account and add to litellm_config.yaml.
    }
  },
  "mcp": {
    "powerbrain": {
      "type": "remote",
      "url": "http://localhost:8080/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer kb_dev_localonly_do_not_use_in_production"
      }
    }
  }
}
